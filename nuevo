local function Tween(obj, props, dur, style)
    TweenService:Create(obj, TweenInfo.new(dur or 0.4, style or Enum.EasingStyle.Quart), props):Play()
end

local function Notify(title, text)
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = 3
        })
    end)
end


local isMinimized = false
local isOpen = true


local function OpenGUI()
    task.wait(1.2)
    
    Tween(LoadingText, {TextTransparency = 1}, 0.4)
    task.wait(0.4)
    LoadingText:Destroy()
    
    MainFrame.Visible = true
    Tween(Blur, {Size = 24}, 0.5)
    Tween(MainFrame, {BackgroundTransparency = 0}, 0.3)
    task.wait(0.1)
    
    Tween(LogoText, {TextTransparency = 0}, 0.3)
    Tween(TitleText, {TextTransparency = 0}, 0.3)
    Tween(SubtitleText, {TextTransparency = 0}, 0.3)
    Tween(CloseBtn, {TextTransparency = 0}, 0.3)
    task.wait(0.1)
    Tween(GroupBtn, {BackgroundTransparency = 0, TextTransparency = 0}, 0.3)
    task.wait(0.1)
    Tween(DiscordBtn, {BackgroundTransparency = 0, TextTransparency = 0}, 0.3)
    task.wait(0.1)
    Tween(ScriptBtn, {BackgroundTransparency = 0, TextTransparency = 0}, 0.3)
    
    isOpen = true
    Notify("Kairox Hub", "Presiona CTRL para ocultar/mostrar")
end


local function Minimize()
    if isMinimized or not isOpen then return end
    isMinimized = true
    
    Tween(Blur, {Size = 0}, 0.3)
    Tween(MainFrame, {BackgroundTransparency = 1}, 0.3)
    Tween(LogoText, {TextTransparency = 1}, 0.2)
    Tween(TitleText, {TextTransparency = 1}, 0.2)
    Tween(SubtitleText, {TextTransparency = 1}, 0.2)
    Tween(CloseBtn, {TextTransparency = 1}, 0.2)
    Tween(GroupBtn, {BackgroundTransparency = 1, TextTransparency = 1}, 0.2)
    Tween(DiscordBtn, {BackgroundTransparency = 1, TextTransparency = 1}, 0.2)
    Tween(ScriptBtn, {BackgroundTransparency = 1, TextTransparency = 1}, 0.2)
    
    task.wait(0.4)
    MainFrame.Visible = false
    
    MiniBtn.Visible = true
    MiniBtn.Size = UDim2.new(0, 0, 0, 0)
    Tween(MiniBtn, {Size = UDim2.new(0, 60, 0, 60)}, 0.3, Enum.EasingStyle.Back)
end


local function Restore()
    if not isMinimized or not isOpen then return end
    isMinimized = false
    
    Tween(MiniBtn, {Size = UDim2.new(0, 0, 0, 0)}, 0.2)
    task.wait(0.2)
    MiniBtn.Visible = false
    
    MainFrame.Visible = true
    Tween(Blur, {Size = 24}, 0.4)
    Tween(MainFrame, {BackgroundTransparency = 0}, 0.4)
    Tween(LogoText, {TextTransparency = 0}, 0.3)
    Tween(TitleText, {TextTransparency = 0}, 0.3)
    Tween(SubtitleText, {TextTransparency = 0}, 0.3)
    Tween(CloseBtn, {TextTransparency = 0}, 0.3)
    Tween(GroupBtn, {BackgroundTransparency = 0, TextTransparency = 0}, 0.3)
    Tween(DiscordBtn, {BackgroundTransparency = 0, TextTransparency = 0}, 0.3)
    Tween(ScriptBtn, {BackgroundTransparency = 0, TextTransparency = 0}, 0.3)
end


local function ToggleHub()
    if not isOpen then return end
    
    if isMinimized then
        Restore()
    else
        Minimize()
    end
end


local function ShowModal()
    Modal.Visible = true
    Modal.BackgroundTransparency = 1
    ConfirmBox.BackgroundTransparency = 1
    ConfirmTitle.TextTransparency = 1
    ConfirmTxt.TextTransparency = 1
    YesBtn.BackgroundTransparency = 1
    YesBtn.TextTransparency = 1
    NoBtn.BackgroundTransparency = 1
    NoBtn.TextTransparency = 1
    
    Tween(Modal, {BackgroundTransparency = 0.7}, 0.2)
    Tween(ConfirmBox, {BackgroundTransparency = 0}, 0.3)
    task.wait(0.1)
    Tween(ConfirmTitle, {TextTransparency = 0}, 0.2)
    Tween(ConfirmTxt, {TextTransparency = 0}, 0.2)
    Tween(YesBtn, {BackgroundTransparency = 0, TextTransparency = 0}, 0.2)
    Tween(NoBtn, {BackgroundTransparency = 0, TextTransparency = 0}, 0.2)
end

local function HideModal()
    Tween(ConfirmTitle, {TextTransparency = 1}, 0.2)
    Tween(ConfirmTxt, {TextTransparency = 1}, 0.2)
    Tween(YesBtn, {BackgroundTransparency = 1, TextTransparency = 1}, 0.2)
    Tween(NoBtn, {BackgroundTransparency = 1, TextTransparency = 1}, 0.2)
    task.wait(0.1)
    Tween(ConfirmBox, {BackgroundTransparency = 1}, 0.2)
    Tween(Modal, {BackgroundTransparency = 1}, 0.2)
    task.wait(0.3)
    Modal.Visible = false
end

-- Cerrar todo definitivamente
local function CloseAll()
    isOpen = false
    HideModal()
    task.wait(0.3)
    
    Tween(Blur, {Size = 0}, 0.3)
    Tween(MainFrame, {BackgroundTransparency = 1}, 0.3)
    Tween(LogoText, {TextTransparency = 1}, 0.2)
    Tween(TitleText, {TextTransparency = 1}, 0.2)
    Tween(SubtitleText, {TextTransparency = 1}, 0.2)
    Tween(CloseBtn, {TextTransparency = 1}, 0.2)
    Tween(GroupBtn, {BackgroundTransparency = 1, TextTransparency = 1}, 0.2)
    Tween(DiscordBtn, {BackgroundTransparency = 1, TextTransparency = 1}, 0.2)
    Tween(ScriptBtn, {BackgroundTransparency = 1, TextTransparency = 1}, 0.2)
    
    task.wait(0.5)
    
    ScreenGui:Destroy()
    Blur:Destroy()
    
    Notify("Kairox Hub", "Script cerrado. ¡Hasta pronto!")
end


CloseBtn.MouseButton1Click:Connect(ShowModal)
YesBtn.MouseButton1Click:Connect(CloseAll)
NoBtn.MouseButton1Click:Connect(HideModal)
MiniBtn.MouseButton1Click:Connect(Restore)

-- CTRL - Toggle perfecto
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.LeftControl or input.KeyCode == Enum.KeyCode.RightControl then
        ToggleHub()
    end
end)

